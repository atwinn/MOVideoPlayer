{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOVideoPlayer",
  "version": "0.1.0",
  "identifier": "dev.movideoplayer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MOVideoPlayer",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 320,
        "decorations": true,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "dragDropEnabled": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/mpv/*"],
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    }
  }
}
